# Production Environment Configuration
# Copy this file to .env.production for production deployment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string with SSL
# Format: postgresql://username:password@host:port/database?sslmode=require
# IMPORTANT: Use strong password and enable SSL in production
DATABASE_URL="postgresql://seo_admin:CHANGE_THIS_PASSWORD@localhost:5432/seo_tool_production?sslmode=require"

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string with password
# Format: redis://:password@host:port
# IMPORTANT: Always use password authentication in production
REDIS_URL="redis://:CHANGE_THIS_PASSWORD@localhost:6379"

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing
# CRITICAL: Use a strong random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER use the same secret across environments
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MINIMUM_32_CHARACTERS"

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# OpenAI API key for content optimization features
# Get your key from: https://platform.openai.com/api-keys
# IMPORTANT: Use production API key with appropriate rate limits
OPENAI_API_KEY="sk-your-production-openai-api-key"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for the backend server
PORT=3001

# Node environment (must be 'production')
NODE_ENV=production

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging level (error, warn, info)
# Use 'info' or 'warn' in production to reduce log volume
LOG_LEVEL=info

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Disable detailed error messages in production
SHOW_STACK_TRACES=false

# Disable Prisma telemetry
PRISMA_TELEMETRY_DISABLED=true

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated)
# CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# Rate limiting configuration
# RATE_LIMIT_WINDOW_MS=3600000
# RATE_LIMIT_MAX_FREE=100
# RATE_LIMIT_MAX_PRO=1000

# Session configuration
# SESSION_TIMEOUT_HOURS=24

# =============================================================================
# MONITORING & ALERTS (Optional)
# =============================================================================
# Sentry DSN for error tracking
# SENTRY_DSN="https://your-sentry-dsn"

# New Relic license key
# NEW_RELIC_LICENSE_KEY="your-license-key"

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. NEVER commit this file with real credentials to version control
# 2. Use strong, randomly generated passwords for all services
# 3. Rotate secrets regularly (at least every 90 days)
# 4. Use different secrets for each environment
# 5. Enable SSL/TLS for all database and cache connections
# 6. Restrict database and Redis access to application servers only
# 7. Use environment-specific API keys for external services
# 8. Enable audit logging for all production systems
# 9. Set up monitoring and alerting for security events
# 10. Regularly review and update security configurations
