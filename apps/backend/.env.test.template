# Test Environment Configuration
# Copy this file to .env.test for running tests

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string for test database
# IMPORTANT: Use a separate test database to avoid data loss
DATABASE_URL="postgresql://postgres:1234@localhost:5432/seo_tool_test"

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string for test cache
# Can use same Redis instance with different database number
REDIS_URL="redis://localhost:6379/1"

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing in tests
# Can use a simple value for testing
JWT_SECRET="test-secret-key-for-testing-only"

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# OpenAI API key for tests
# Use a test/development key or mock the API in tests
OPENAI_API_KEY="sk-test-key-or-mock"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for test server (different from development)
PORT=3002

# Node environment (must be 'test')
NODE_ENV=test

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging level for tests (use 'error' to reduce noise)
LOG_LEVEL=error

# =============================================================================
# TEST CONFIGURATION
# =============================================================================
# Disable telemetry during tests
PRISMA_TELEMETRY_DISABLED=true

# Enable detailed error messages for debugging tests
SHOW_STACK_TRACES=true

# Disable external API calls in tests (optional)
# MOCK_EXTERNAL_APIS=true

# =============================================================================
# NOTES
# =============================================================================
# 1. Test database is automatically reset before each test run
# 2. Use a separate Redis database number to avoid conflicts
# 3. Mock external services (OpenAI, web scraping) in tests when possible
# 4. Keep test environment isolated from development and production
